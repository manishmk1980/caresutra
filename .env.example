# MySQL (Prisma ORM 7 — app uses `@prisma/adapter-mariadb` + `mariadb` driver; `mysql://` URLs are supported)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/caresutra_db"

# Phase 1 admin dashboard — use strong values in local .env (never commit .env)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"
ADMIN_SESSION_SECRET="change-this-long-random-secret"

# Public booking integration
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/YOUR-CALENDLY-USERNAME/30min"
