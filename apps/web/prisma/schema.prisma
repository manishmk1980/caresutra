// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model CustomerActivity {
  id              Int      @id @default(autoincrement())
  customerName    String
  mobile          String
  email           String?
  city            String?
  serviceInterest String
  customerType    String
  leadSource      String?
  currentStatus   String
  followUpDate    DateTime?
  notes           String?
  assignedTo      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CustomerRecord {
  id                   Int                   @id @default(autoincrement())

  firstName            String?
  middleName           String?
  lastName             String?
  email                String?
  mobile               String?
  alternativeMobile    String?
  dateOfBirth          DateTime?
  pan                  String?
  aadhaar              String?

  addressLine          String?
  floor                String?
  street               String?
  city                 String?
  state                String?
  pinCode              String?

customerPictureUrl   String?
  panDocumentUrl        String?
  aadharFrontUrl        String?
  aadharBackUrl         String?
  otherDocumentUrl      String?

  customerStatus       CustomerStatus        @default(PROSPECT)
  customerType         CustomerType?

  providerCompanyName  String?
  serviceCommencedDate DateTime?
  expiryDate           DateTime?
  insuranceLoanAmount  Decimal?              @db.Decimal(12, 2)
  premiumEmi           Decimal?              @db.Decimal(12, 2)
  coverFinalPayout     Decimal?              @db.Decimal(12, 2)

  recordStatus         CustomerRecordStatus  @default(DRAFT)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

enum CustomerRecordStatus {
  DRAFT
  SUBMITTED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum CustomerType {
  INSURANCE
  LOAN
  HEALTHCARE
}

model AppointmentRequest {
  id                     Int               @id @default(autoincrement())
  fullName               String
  email                  String
  mobile                 String
  whatsapp               String?
  telegram               String?
  city                   String?
  serviceInterest        String
  preferredContactMethod String
  preferredDate          DateTime?
  preferredTimeSlot      String?
  message                String?
  consentAccepted        Boolean           @default(false)
  status                 AppointmentStatus @default(NEW)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

enum AppointmentStatus {
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}
